<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <changeSet id="019-create-notification-campaigns-table" author="tourguide">
        <createTable tableName="notification_campaigns">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="title" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="body" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="target_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="target_payload" type="jsonb"/>
            <column name="deep_link" type="varchar(500)"/>
            <column name="data" type="jsonb"/>
            <column name="status" type="varchar(30)" defaultValue="DRAFT">
                <constraints nullable="false"/>
            </column>
            <column name="created_by" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="sent_at" type="timestamp"/>
            <column name="total_recipients" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="success_count" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="failure_count" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp"/>
        </createTable>

        <addForeignKeyConstraint baseTableName="notification_campaigns"
                                 baseColumnNames="created_by"
                                 referencedTableName="users"
                                 referencedColumnNames="id"
                                 constraintName="fk_notification_campaigns_created_by"/>

        <createIndex indexName="idx_notification_campaigns_created_at" tableName="notification_campaigns">
            <column name="created_at"/>
        </createIndex>

        <createIndex indexName="idx_notification_campaigns_status" tableName="notification_campaigns">
            <column name="status"/>
        </createIndex>
    </changeSet>

    <changeSet id="019-extend-notifications-table-for-push" author="tourguide">
        <addColumn tableName="notifications">
            <column name="campaign_id" type="uuid"/>
            <column name="deep_link" type="varchar(500)"/>
            <column name="data" type="jsonb"/>
            <column name="push_status" type="varchar(30)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="push_error" type="text"/>
            <column name="sent_at" type="timestamp"/>
        </addColumn>

        <addForeignKeyConstraint baseTableName="notifications"
                                 baseColumnNames="campaign_id"
                                 referencedTableName="notification_campaigns"
                                 referencedColumnNames="id"
                                 constraintName="fk_notifications_campaign"/>

        <createIndex indexName="idx_notifications_campaign" tableName="notifications">
            <column name="campaign_id"/>
        </createIndex>
    </changeSet>

    <changeSet id="019-extend-device-tokens-table" author="tourguide">
        <addColumn tableName="device_tokens">
            <column name="provider" type="varchar(30)" defaultValue="FCM">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="last_seen_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp"/>
        </addColumn>

        <createIndex indexName="idx_device_tokens_user_active" tableName="device_tokens">
            <column name="user_id"/>
            <column name="is_active"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
